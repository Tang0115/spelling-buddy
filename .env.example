# Copy to .env.local and paste your key from https://dashboard.clerk.com/~/api-keys
# Must use the VITE_ prefix (not NEXT_PUBLIC_) — see https://vitejs.dev/guide/env-and-mode.html
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Optional Puter.js: set to "false" to use browser Speech Synthesis only (no cloud TTS).
# VITE_USE_PUTER_AI=false
# Optional: use Puter Whisper for spelling instead of Web Speech API (needs network / Puter).
# VITE_STT_PUTER=true
